{
  "name": "sydeinnovation",
  "private": true,
  "version": "1.0.0",
  "description": "SydeInnovation - Design Engineering & CAD Automation with APS Integration",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "dev:server": "node server/start.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "vite build",
    "build:admin": "cd admin-console && npm run build && xcopy /E /I /Y out ..\\server\\admin-console",
    "build:all": "npm run build && npm run build:admin",
    "start": "node server/start.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "@vercel/analytics": "^2.0.1",
    "archiver": "^7.0.1",
    "autodesk.forge.designautomation": "^3.0.5",
    "axios": "^1.13.2",
    "body-parser": "^1.20.4",
    "concurrently": "^8.2.2",
    "cookie-session": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "forge-apis": "^0.9.11",
    "form-data": "^4.0.5",
    "lucide-react": "^0.344.0",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.12.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
