{
  "schemaVersion": "1.0",
  "productId": "configurable-bracket",
  "name": "Configurable Mounting Bracket",
  "description": "Adjustable mounting bracket with multiple hole patterns and material options. Ideal for industrial equipment mounting.",
  "category": "brackets",
  "thumbnail": "/images/products/bracket.png",

  "cadModel": {
    "inputFile": "MountingBracket.ipt",
    "activityId": "UpdateIPTParamActivity",
    "engineVersion": "2025",
    "description": "Inventor part file with configurable parameters"
  },

  "parameterGroups": [
    { "id": "dimensions", "label": "Dimensions", "icon": "Ruler", "order": 1 },
    { "id": "holes", "label": "Hole Pattern", "icon": "Grid3x3", "order": 2 },
    { "id": "material", "label": "Material", "icon": "Layers", "order": 3 },
    { "id": "finish", "label": "Finish", "icon": "Palette", "order": 4 }
  ],

  "parameters": [
    {
      "id": "length",
      "label": "Overall Length",
      "inventorParam": "Length",
      "type": "slider",
      "min": 100,
      "max": 500,
      "step": 10,
      "default": 200,
      "unit": "mm",
      "group": "dimensions",
      "description": "Total length of the bracket"
    },
    {
      "id": "width",
      "label": "Overall Width",
      "inventorParam": "Width",
      "type": "slider",
      "min": 50,
      "max": 200,
      "step": 5,
      "default": 100,
      "unit": "mm",
      "group": "dimensions"
    },
    {
      "id": "thickness",
      "label": "Material Thickness",
      "inventorParam": "Thickness",
      "type": "select",
      "options": [
        { "value": "3", "label": "3mm - Light Duty", "priceMultiplier": 1.0 },
        { "value": "5", "label": "5mm - Standard", "priceMultiplier": 1.3, "default": true },
        { "value": "8", "label": "8mm - Heavy Duty", "priceMultiplier": 1.8 },
        { "value": "10", "label": "10mm - Extra Heavy", "priceMultiplier": 2.2 }
      ],
      "unit": "mm",
      "group": "dimensions"
    },
    {
      "id": "bendAngle",
      "label": "Bend Angle",
      "inventorParam": "BendAngle",
      "type": "slider",
      "min": 45,
      "max": 135,
      "step": 5,
      "default": 90,
      "unit": "°",
      "group": "dimensions",
      "description": "Angle of the bracket bend"
    },
    {
      "id": "holePattern",
      "label": "Hole Pattern",
      "inventorParam": "HolePattern",
      "type": "radio",
      "options": [
        { "value": "single", "label": "Single Row", "priceAdd": 0 },
        { "value": "double", "label": "Double Row", "priceAdd": 15, "default": true },
        { "value": "grid", "label": "Grid Pattern", "priceAdd": 30 },
        { "value": "slotted", "label": "Slotted Holes", "priceAdd": 25 }
      ],
      "group": "holes"
    },
    {
      "id": "holeCount",
      "label": "Holes Per Row",
      "inventorParam": "HoleCount",
      "type": "slider",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "group": "holes"
    },
    {
      "id": "holeDiameter",
      "label": "Hole Diameter",
      "inventorParam": "HoleDia",
      "type": "select",
      "options": [
        { "value": "6", "label": "M6 (6mm)" },
        { "value": "8", "label": "M8 (8mm)", "default": true },
        { "value": "10", "label": "M10 (10mm)" },
        { "value": "12", "label": "M12 (12mm)" }
      ],
      "unit": "mm",
      "group": "holes"
    },
    {
      "id": "material",
      "label": "Material Type",
      "inventorParam": "Material",
      "type": "radio",
      "options": [
        { "value": "steel", "label": "Carbon Steel", "priceMultiplier": 1.0, "default": true },
        { "value": "stainless", "label": "Stainless Steel 304", "priceMultiplier": 2.5 },
        { "value": "stainless316", "label": "Stainless Steel 316", "priceMultiplier": 3.2 },
        { "value": "aluminum", "label": "Aluminum 6061", "priceMultiplier": 1.8 }
      ],
      "group": "material"
    },
    {
      "id": "finish",
      "label": "Surface Finish",
      "inventorParam": "Finish",
      "type": "radio",
      "options": [
        { "value": "raw", "label": "Raw / Mill Finish", "priceAdd": 0 },
        { "value": "zinc", "label": "Zinc Plated", "priceAdd": 8, "default": true },
        { "value": "powder", "label": "Powder Coated", "priceAdd": 15 },
        { "value": "anodized", "label": "Anodized (Aluminum only)", "priceAdd": 20 }
      ],
      "group": "finish"
    },
    {
      "id": "color",
      "label": "Powder Coat Color",
      "inventorParam": "Color",
      "type": "color",
      "options": [
        { "value": "black", "label": "Black", "hex": "#1a1a1a", "default": true },
        { "value": "white", "label": "White", "hex": "#f5f5f5" },
        { "value": "red", "label": "Safety Red", "hex": "#cc0000" },
        { "value": "yellow", "label": "Safety Yellow", "hex": "#ffcc00" },
        { "value": "blue", "label": "Industrial Blue", "hex": "#0066cc" },
        { "value": "gray", "label": "Gray", "hex": "#666666" }
      ],
      "group": "finish",
      "description": "Only applies when Powder Coated finish is selected"
    }
  ],

  "rules": [
    {
      "id": "anodized-aluminum-only",
      "name": "Anodized requires Aluminum",
      "condition": "material !== 'aluminum' && finish === 'anodized'",
      "actions": [
        { "type": "disable", "parameter": "finish", "optionValue": "anodized" },
        { "type": "warn", "message": "Anodized finish is only available for Aluminum material" }
      ]
    },
    {
      "id": "color-powder-only",
      "name": "Color requires Powder Coat",
      "condition": "finish !== 'powder'",
      "actions": [
        { "type": "hide", "parameter": "color" }
      ]
    },
    {
      "id": "grid-min-width",
      "name": "Grid pattern minimum width",
      "condition": "holePattern === 'grid' && width < 80",
      "actions": [
        { "type": "setMin", "parameter": "width", "value": 80 },
        { "type": "warn", "message": "Grid pattern requires minimum 80mm width" }
      ]
    },
    {
      "id": "heavy-duty-thickness",
      "name": "Heavy loads need thicker material",
      "condition": "length > 400 && thickness < 8",
      "actions": [
        { "type": "warn", "message": "Brackets over 400mm recommended with 8mm+ thickness for structural integrity" }
      ]
    },
    {
      "id": "hole-count-length",
      "name": "Hole count based on length",
      "condition": "length < 150",
      "actions": [
        { "type": "setMax", "parameter": "holeCount", "value": 4 }
      ]
    }
  ],

  "pricing": {
    "currency": "USD",
    "basePrice": 25,
    "formula": "basePrice + (surfaceArea * surfaceRate * materialMultiplier) + optionPrices + finishPrice",
    "calculations": {
      "surfaceRate": 0.0008,
      "surfaceArea": "length * width"
    },
    "discounts": [
      { "minQuantity": 10, "percentage": 5 },
      { "minQuantity": 25, "percentage": 10 },
      { "minQuantity": 50, "percentage": 15 },
      { "minQuantity": 100, "percentage": 20 }
    ]
  },

  "outputs": {
    "3dModel": {
      "enabled": true,
      "formats": ["ipt", "step", "iges", "sat"]
    },
    "drawings": {
      "enabled": true,
      "types": ["production", "assembly"],
      "formats": ["pdf", "dwg", "dxf"]
    },
    "bom": {
      "enabled": true,
      "format": "xlsx"
    }
  },

  "metadata": {
    "createdAt": "2025-01-14T00:00:00Z",
    "updatedAt": "2025-01-14T00:00:00Z",
    "version": "1.0.0",
    "status": "active",
    "author": "SydeFlow"
  }
}
